<resources>
    <style name="Theme.DogCuisine" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/dog_primary</item>
        <item name="colorOnPrimary">@color/dog_on_primary</item>
        <item name="colorPrimaryContainer">@color/dog_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/dog_on_primary_container</item>

        <item name="colorSecondary">@color/dog_secondary</item>
        <item name="colorOnSecondary">@color/dog_on_secondary</item>
        <item name="colorSecondaryContainer">@color/dog_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/dog_on_secondary_container</item>

        <item name="colorSurface">@color/dog_surface</item>
        <item name="colorSurfaceVariant">@color/dog_surface_variant</item>
        <item name="colorOnSurface">@color/dog_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/dog_on_surface_variant</item>
        <item name="colorOutline">@color/dog_outline</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowBackground">?attr/colorSurface</item>

        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>
        <item name="materialCardViewStyle">@style/Widget.MaterialComponents.CardView</item>
        <item name="toolbarStyle">@style/Widget.DogCuisine.Toolbar</item>
    </style>

    <style name="Theme.DogCuisine.Splash" parent="Theme.SplashScreen.IconBackground">
        <item name="windowSplashScreenBackground">@color/dog_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_ic_launcher_inset</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/dog_primary</item>
        <item name="postSplashScreenTheme">@style/Theme.DogCuisine</item>
    </style>
</resources>
