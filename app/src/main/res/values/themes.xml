<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.DogCuisine" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 主题色保留现有主辅色 -->
        <item name="colorPrimary">@color/dog_primary</item>
        <item name="colorOnPrimary">@color/dog_on_primary</item>
        <item name="colorPrimaryContainer">@color/dog_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/dog_on_primary_container</item>

        <item name="colorSecondary">@color/dog_secondary</item>
        <item name="colorOnSecondary">@color/dog_on_secondary</item>
        <item name="colorSecondaryContainer">@color/dog_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/dog_on_secondary_container</item>

        <item name="colorSurface">@color/dog_surface</item>
        <item name="colorSurfaceVariant">@color/dog_surface_variant</item>
        <item name="colorOnSurface">@color/dog_on_surface</item>
        <item name="colorOnSurfaceVariant">@color/dog_on_surface_variant</item>
        <item name="colorOutline">@color/dog_outline</item>

        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowBackground">?attr/colorSurface</item>

        <!-- 全局控件风格：使用 Material3；CardView 使用兼容样式避免缺失 -->
        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>
        <item name="materialCardViewStyle">@style/Widget.MaterialComponents.CardView</item>
        <item name="toolbarStyle">@style/Widget.DogCuisine.Toolbar</item>
    </style>

    <style name="Theme.DogCuisine.Splash" parent="Theme.SplashScreen.IconBackground">
        <item name="windowSplashScreenBackground">@color/dog_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_ic_launcher_inset</item>
        <item name="windowSplashScreenAnimationDuration">1000</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/dog_primary</item>
        <item name="postSplashScreenTheme">@style/Theme.DogCuisine</item>
    </style>

    <style name="Widget.DogCuisine.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="titleTextColor">?attr/colorOnPrimary</item>
        <item name="subtitleTextColor">?attr/colorOnPrimary</item>
        <item name="navigationIconTint">?attr/colorOnPrimary</item>
        <item name="popupTheme">@style/ThemeOverlay.Material3.Light</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="TextAppearance.DogCuisine.Button" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textSize">14sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="Widget.DogCuisine.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorSecondary</item>
        <item name="android:textColor">?attr/colorSecondary</item>
        <item name="android:textAppearance">@style/TextAppearance.DogCuisine.Button</item>
    </style>

    <style name="ThemeOverlay.DogCuisine.BottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/Widget.DogCuisine.BottomSheet.Modal</item>
    </style>

    <style name="Widget.DogCuisine.BottomSheet.Modal" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">@color/dog_gradient_bottom</item>
    </style>
</resources>
